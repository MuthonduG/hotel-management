# Copy to `.env` in this folder (`frontend/.env`).
# Base URL for the hotel API (no trailing slash). Example paths: /auth/login, /admin/staff
VITE_API_BASE_URL=http://localhost:4000/api

# Session: auto sign-out after this many milliseconds of no activity (default 900000 = 15 minutes)
# JWT: if the access token has exp, the client also signs out when it expires.
VITE_SESSION_INACTIVITY_MS=900000
