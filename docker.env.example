# Copy to `.env` in repo root (optional) - Docker Compose reads these variables
# Example: `docker compose --env-file .env up --build`

POSTGRES_USER=hotel
POSTGRES_PASSWORD=hotel
POSTGRES_DB=hotel
# POSTGRES_PORT=5433
# BACKEND_PORT=4000

JWT_SECRET=change-me-jwt-secret-min-32-chars-recommended
# JWT_EXPIRES_IN=8h

# First Admin account (only applied when the `staff` table has no Admin yet)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-bootstrap-password-in-production
BOOTSTRAP_ADMIN_NAME=Administrator
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com

CORS_ORIGIN=http://localhost:5173
